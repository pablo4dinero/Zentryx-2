# ── Zentryx API server — environment template ──────────────────────────
# Copy this file to `.env` (or set in Render's dashboard) and fill in
# the real values. `.env` is git-ignored.

# Port (Render sets this automatically; required locally too)
PORT=3000

# Postgres — Render provides DATABASE_URL automatically
DATABASE_URL=postgres://user:password@localhost:5432/zentryx

# ── Required: JWT signing secret ─────────────────────────────────────
# Must be at least 32 chars. Generate one with:
#   node -e "console.log(require('crypto').randomBytes(48).toString('base64'))"
# Server refuses to boot if missing.
JWT_SECRET=

# ── Required in production: CORS allow-list ──────────────────────────
# Comma-separated list of allowed origins. Server refuses to boot in
# production (NODE_ENV=production) if this is empty.
# Example: https://zentryx.onrender.com,https://app.zentryx.com
CORS_ORIGINS=

# ── Required: Superadmin bootstrap credentials ───────────────────────
# Both must be set. Server refuses to boot if either is missing or if
# the hash doesn't look like a bcrypt hash. The password is stored as a
# bcrypt HASH only — never paste plaintext into env vars.
#
# Generate the hash locally (it'll prompt with no echo):
#   node scripts/hash-password.cjs
# Then paste the output into SUPERADMIN_PASSWORD_HASH.
SUPERADMIN_EMAIL=
SUPERADMIN_PASSWORD_HASH=

# ── Cloudflare R2 (object storage for chat attachments) ──────────────
# Required for any upload to succeed. R2 is S3-compatible; the AWS SDK
# is pointed at the R2 endpoint with `region: "auto"`. Files are stored
# privately and served via short-lived signed URLs from the API.
R2_ENDPOINT=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_NAME=

# ── Email (Resend) ───────────────────────────────────────────────────
# If RESEND_API_KEY is missing the server runs in "dev mode" and prints
# OTPs to console instead of sending email. Production MUST set this.
RESEND_API_KEY=
RESEND_FROM_EMAIL=onboarding@resend.dev

# ── Required in production: OAuth email-domain allow-list ───────────
# Comma-separated list of domains permitted to sign in via Microsoft or
# Google OAuth. Any other domain is bounced at the callback with the
# `domain_not_allowed` error code. In production an empty list blocks
# everything (fail-loud); in development an empty list permits any
# domain for local testing.
# Example: freddyhirsch.co.za,zentryx.dev
ALLOWED_EMAIL_DOMAINS=freddyhirsch.co.za

# ── SMS (Termii — Nigeria-native, used only for MFA fallback) ────────
# When TOTP fails 3 times, users can request a one-time SMS or voice
# call OTP via Termii. Not used for routine login.
TERMII_API_KEY=
TERMII_SENDER_ID=Zentryx
TERMII_CHANNEL=dnd

# ── External APIs ────────────────────────────────────────────────────
ANTHROPIC_API_KEY=
NEWS_API_KEY=

# ── Misc ─────────────────────────────────────────────────────────────
NODE_ENV=development
