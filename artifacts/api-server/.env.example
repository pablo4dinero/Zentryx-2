# ── Zentryx API server — environment template ──────────────────────────
# Copy this file to `.env` (or set in Render's dashboard) and fill in
# the real values. `.env` is git-ignored.

# Port (Render sets this automatically; required locally too)
PORT=3000

# Postgres — Render provides DATABASE_URL automatically
DATABASE_URL=postgres://user:password@localhost:5432/zentryx

# ── Required: JWT signing secret ─────────────────────────────────────
# Must be at least 32 chars. Generate one with:
#   node -e "console.log(require('crypto').randomBytes(48).toString('base64'))"
# Server refuses to boot if missing.
JWT_SECRET=

# ── Required in production: CORS allow-list ──────────────────────────
# Comma-separated list of allowed origins. Server refuses to boot in
# production (NODE_ENV=production) if this is empty.
# Example: https://zentryx.onrender.com,https://app.zentryx.com
CORS_ORIGINS=

# ── Cloudflare R2 (object storage for chat attachments) ──────────────
# Required for any upload to succeed. R2 is S3-compatible; the AWS SDK
# is pointed at the R2 endpoint with `region: "auto"`. Files are stored
# privately and served via short-lived signed URLs from the API.
R2_ENDPOINT=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_NAME=

# ── Email (Resend) ───────────────────────────────────────────────────
# If RESEND_API_KEY is missing the server runs in "dev mode" and prints
# OTPs to console instead of sending email. Production MUST set this.
RESEND_API_KEY=
RESEND_FROM_EMAIL=onboarding@resend.dev

# ── SMS (optional, for phone-OTP MFA) ────────────────────────────────
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=

# ── External APIs ────────────────────────────────────────────────────
ANTHROPIC_API_KEY=
NEWS_API_KEY=

# ── Misc ─────────────────────────────────────────────────────────────
NODE_ENV=development
